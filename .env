# ══════════════════════════════════════════════════════
#  Mini Marketplace — Environment Variables
#  Copy this file to .env and customise before deploying.
#  NEVER commit real credentials to version control.
# ══════════════════════════════════════════════════════

# ── PostgreSQL ─────────────────────────────────────────
POSTGRES_DB=mini_marketplace
POSTGRES_USER=marketplace_user
POSTGRES_PASSWORD=marketplace_pass

# ── Spring profile ─────────────────────────────────────
# 'prod'  → minimal logging, no SQL output
# 'dev'   → verbose logging, formatted SQL
SPRING_PROFILES_ACTIVE=prod
