# Copy to .env and fill your real values.
# Choose one DB_URL source: local Docker/Postgres OR Render internal URL.

# Local example:
# DB_URL=jdbc:postgresql://localhost:5432/mini_marketplace

# Render Postgres example (from your Render database panel):
# Internal URL format: jdbc:postgresql://<hostname>:<port>/<database>
DB_URL=jdbc:postgresql://YOUR_RENDER_HOST:5432/YOUR_DATABASE_NAME
DB_USERNAME=YOUR_DATABASE_USERNAME
DB_PASSWORD=YOUR_DATABASE_PASSWORD

# Optional aliases (Render/common PaaS style)
DATABASE_URL=
DATABASE_USERNAME=
DATABASE_PASSWORD=

SPRING_PROFILES_ACTIVE=prod

POSTGRES_DB=mini_marketplace
POSTGRES_USER=marketplace_user
POSTGRES_PASSWORD=replace_with_real_password
